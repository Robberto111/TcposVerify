@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TCPOS Verify</title>
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            background: #2c3e50;
            color: white;
            padding: 20px;
        }
        .card {
            text-align: center;
            background: rgba(0,0,0,0.2);
            padding: 40px 32px;
            border-radius: 20px;
            border: 2px solid rgba(255,255,255,0.15);
            max-width: 400px;
            width: 100%;
            box-shadow: 0 8px 32px rgba(0,0,0,0.3);
        }
        .logo {
            font-size: 0.85em;
            opacity: 0.5;
            letter-spacing: 3px;
            text-transform: uppercase;
            margin-bottom: 24px;
        }
        .titolo {
            font-size: 1.4em;
            font-weight: 600;
            line-height: 1.4;
            opacity: 0.9;
        }
        .footer {
            margin-top: 32px;
            font-size: 0.72em;
            opacity: 0.3;
        }
    </style>
</head>
<body>
    <div class="card">
        <div class="logo">TCPOS Verify</div>
        <div class="titolo">Servizio verifica autenticità scontrini</div>
        <div class="footer">Scansiona il QR code presente sullo scontrino</div>
    </div>
</body>
</html>