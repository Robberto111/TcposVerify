function getRealIp(): string {
    return $_SERVER['REMOTE_ADDR'] ?? '0.0.0.0';
}

function checkRateLimit(string $ip, string $current_tr): array {
    if (!is_dir(RATE_LIMIT_FOLDER)) mkdir(RATE_LIMIT_FOLDER, 0750, true);
    $file = RATE_LIMIT_FOLDER . md5($ip) . '.json';
    $now = time();
    
    // Struttura dati avanzata
    $dati = [
        'requests' => [], 
        'different_trans' => [], // Array di [tr => timestamp]
        'blocked_until' => 0,
        'silent_block' => false
    ];

    if (file_exists($file)) {
        $decoded = json_decode(file_get_contents($file), true);
        if (is_array($decoded)) $dati = array_merge($dati, $decoded);
    }

    // Se è in corso un blocco (normale o silent)
    if ($dati['blocked_until'] > $now) {
        return ['ok' => false, 'silent' => $dati['silent_block']];
    }

    // 1. Pulizia vecchi dati (finestra 5 minuti per i bot, 1 minuto per rate limit)
    $dati['requests'] = array_values(array_filter($dati['requests'], fn($t) => $t > $now - 60));
    foreach ($dati['different_trans'] as $tr => $t) {
        if ($t < $now - 300) unset($dati['different_trans'][$tr]);
    }

    // 2. Aggiunta richiesta attuale
    $dati['requests'][] = $now;
    if ($current_tr) {
        $dati['different_trans'][$current_tr] = $now;
    }

    // 3. CONTROLLO SILENT BLOCK (Reverse Engineering: > 10 transazioni diverse)
    if (count($dati['different_trans']) > 10) {
        $dati['blocked_until'] = $now + 86400; // 24 ore
        $dati['silent_block'] = true;
        file_put_contents($file, json_encode($dati), LOCK_EX);
        return ['ok' => false, 'silent' => true];
    }

    // 4. CONTROLLO RATE LIMIT NORMALE (> 30 richieste/min)
    if (count($dati['requests']) > RATE_LIMIT_MAX_REQ) {
        $dati['blocked_until'] = $now + RATE_LIMIT_BLOCCO;
        $dati['silent_block'] = false;
        file_put_contents($file, json_encode($dati), LOCK_EX);
        return ['ok' => false, 'silent' => false];
    }

    file_put_contents($file, json_encode($dati), LOCK_EX);
    return ['ok' => true, 'silent' => false];
}

