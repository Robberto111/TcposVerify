function logSicurezza(string $ip, string $evento): void {
    $file = LOG_FOLDER . 'security_' . date('Y-m-d') . '.log';
    $riga = implode('|', [date('Y-m-d H:i:s'), $ip, $evento, $_SERVER['HTTP_USER_AGENT'] ?? 'n/a']) . "\n";
    $fp = fopen($file, 'a');
    if ($fp && flock($fp, LOCK_EX)) { fwrite($fp, $riga); flock($fp, LOCK_UN); fclose($fp); }
}

function logScansione(
    string $neg, string $till, string $trans,
    string $totale_eur, string $data_ora_log, string $esito, string $ip
): int {
    $neg_safe = preg_replace('/[^a-zA-Z0-9_-]/', '', $neg);
    if ($neg_safe === '') $neg_safe = 'SCONOSCIUTO';
    $log_file   = LOG_FOLDER . 'scans_' . $neg_safe . '_' . date('Y-m-d') . '.csv';
    $is_nuovo   = !file_exists($log_file);
    $chiave     = $neg . '|' . $till . '|' . $trans;
    $scan_count = 1;
    if (!$is_nuovo) {
        $handle = fopen($log_file, 'r');
        if ($handle) {
            while (($riga = fgetcsv($handle, 500, ',')) !== false) {
                if (isset($riga[2]) && $riga[2] === $chiave) $scan_count++;
            }
            fclose($handle);
        }
    }
    $fp = fopen($log_file, 'a');
    if ($fp && flock($fp, LOCK_EX)) {
        if ($is_nuovo) fputcsv($fp, ['timestamp','ip','chiave_unica','negozio','cassa','n_transazione','totale_eur','data_ora_scontrino','esito','scan_count','user_agent']);
        fputcsv($fp, [date('Y-m-d H:i:s'), $ip, $chiave, $neg, $till, $trans, $totale_eur, $data_ora_log, $esito, $scan_count, $_SERVER['HTTP_USER_AGENT'] ?? 'n/a']);
        flock($fp, LOCK_UN); fclose($fp);
    }
    return $scan_count;
}

function safeLogScansione($neg, $till, $trans, $totale_eur, $data_ora_log, $esito, $ip) {
    $neg_safe = preg_replace('/[^a-zA-Z0-9_-]/', '', $neg);
    if ($neg_safe === '') $neg_safe = 'SCONOSCIUTO';
    $log_file = LOG_FOLDER . 'scans_' . $neg_safe . '_' . date('Y-m-d') . '.csv';
    
    // Protezione Log Flooding: limite 5MB per file negozio/giorno
    if (file_exists($log_file) && filesize($log_file) > 5 * 1024 * 1024) {
        return 999; // Codice convenzionale per indicare log saturo
    }
    
    return logScansione($neg, $till, $trans, $totale_eur, $data_ora_log, $esito, $ip);
}

function pulisciLogVecchi(): void {
    if (rand(1, 100) !== 1) return;
    $threshold = strtotime('-' . LOG_RETENTION_DAYS . ' days');
    foreach (glob(LOG_FOLDER . '*.{csv,log,json}', GLOB_BRACE) as $file) {
        if (filemtime($file) < $threshold) unlink($file);
    }
    foreach (glob(RATE_LIMIT_FOLDER . '*.json') as $file) {
        if (filemtime($file) < strtotime('-1 day')) unlink($file);
    }
}

