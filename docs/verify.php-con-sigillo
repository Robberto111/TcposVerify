// Funzione per moltiplicazione sicura (evita overflow Double in XSLT)
function safe_mul_mod($a, $b, $mod) {
    $b_hi = floor($b / 1000);
    $b_lo = $b % 1000;
    $res_hi = ($a * $b_hi) % $mod;
    $res = (($res_hi * 1000) + ($a * $b_lo)) % $mod;
    return $res;
}

function calcolaChecksum(
    string $neg, string $ti, string $tr,
    string $d,   string $t,  string $tot
): string {
    // 0. Preparazione dei segreti basati sulla DATA INTERA ($d)
    // Usiamo la data (es. 23022026) per cambiare i secret ogni giorno
    $date_val = intval($d);
    $giorno = intval(substr($d, 0, 2)); // Prende il giorno (es. 23)

    // 1. MASTER KEY DERIVATA con fmod per sicurezza su sistemi 32bit (Non presente nel QR, ma ricostruibile da data)
    // Usiamo un numero primo grande e la data rimescolata
    $k = fmod((float)$date_val * 7919, (float)MOD1);

    $s1 = (982451653 + $date_val + $k) % MOD1;
    $s2 = (15485863 + ($date_val * 7) + $k) % MOD2;
    $s3 = (32452843 + ($date_val * 13) + $k) % MOD3;

    // 2. Pulizia dei codici (via le lettere)
    $neg_num = intval(preg_replace('/[^0-9]/', '', $neg));
    $ti_num  = intval(preg_replace('/[^0-9]/', '', $ti));
    $tr_num  = intval($tr);
    $tot_num = intval($tot);
    // MODULO FINALE VARIABILE (Cambia ogni giorno)
    $mod_finale = 900000000 + ($giorno * 1000000);

    // 3. BIVIO OFFUSCATO (Logica Polimorfica)
    $branch = (($giorno * 17) + 3) % 2;

    if ($branch != 0) {
        // FORMULA DISPARI (Non lineare potenziata)
        $step1 = (($neg_num * $s1) + ($ti_num * $s2)) % MOD1;
        $tmp2  = ($step1 + $tr_num) % MOD2;
        $step2 = safe_mul_mod($tmp2, $s3, MOD2); // FIX PRECISIONE
        $res   = (($step2 * 31) + ($tot_num * 17)) % $mod_finale;
    } else {
        // FORMULA PARI (Invertita e potenziata)
        $step1 = (($tot_num * $s1) + ($tr_num * $s2)) % MOD1;
        $tmp2  = ($step1 + $ti_num) % MOD2;
        $step2 = safe_mul_mod($tmp2, $s3, MOD2); // FIX PRECISIONE
        $res   = (($step2 * 31) + ($neg_num * 17)) % $mod_finale;
    }

    // 4. PADDING DI CONTROLLO (La 10a cifra è la somma delle cifre del totale mod 10)
    // Forza il totale a essere solo numerico prima di calcolare la 10a cifra
    $tot_clean = preg_replace('/[^0-9]/', '', $tot); 
    $cifra_ctrl = array_sum(str_split($tot_clean)) % 10;
    
    return str_pad((int)$res, 9, '0', STR_PAD_LEFT) . $cifra_ctrl;
}

// ============================================================
//  [v3.0] HONEY-TRAP: calcolo parametro h
//
//  h è un secondo token di autenticità calcolato dall'XSLT
//  con una formula ASIMMETRICA rispetto a ck (usa S2 come
//  moltiplicatore principale invece di S1, e incrocia neg+ti
//  attraverso MOD3 invece di MOD1/MOD2).
//
//  Scopo: se il QR viene costruito a mano o da un bot senza
//  conoscere l'algoritmo completo, h sarà errato o mancante.
//  In quel caso il Sigillo Mondrian viene "avvelenato": mostra
//  colori diversi da quelli legittimi. L'attaccante non riceve
//  alcun messaggio di errore esplicito (trappola silenziosa).
//
//  Overflow-safe: tutti i prodotti intermedi restano sotto
//  2^53 (limite IEEE 754 double) grazie a safe_mul_mod().
// ============================================================

function calcolaH(
    string $neg, string $ti, string $tr, string $d
): string {
    $date_val = intval($d);

    // Stessi secret della funzione calcolaChecksum (derivati dalla data)
    $k  = fmod((float)$date_val * 7919, (float)MOD1);
    $s1 = (982451653 + $date_val + $k) % MOD1;
    $s2 = (15485863  + ($date_val * 7) + $k) % MOD2;

    $neg_num = intval(preg_replace('/[^0-9]/', '', $neg));
    $ti_num  = intval(preg_replace('/[^0-9]/', '', $ti));
    $tr_num  = intval($tr);

    // Passo 1: tr_num * S2 mod MOD2 (formula asimmetrica: usa S2, non S1)
    $h_step1 = safe_mul_mod($tr_num, $s2, MOD2);

    // Passo 2: incrocio con neg e ti attraverso MOD3
    $h_tmp   = ($h_step1 + $neg_num + $ti_num) % MOD3;

    // Passo 3: h_tmp * S1 mod MOD1
    $h_val   = safe_mul_mod($h_tmp, $s1, MOD1);

    // Risultato: 5 cifre con zero-padding a sinistra
    return str_pad($h_val % 100000, 5, '0', STR_PAD_LEFT);
}

// ============================================================
//  [v3.0] SIGILLO MONDRIAN - Generatore deterministico LCG
//
//  Genera 4 colori da una palette di 10 usando un Linear
//  Congruential Generator (LCG) con parametri standard glibc.
//  Garantisce risultati identici su qualsiasi versione PHP
//  e qualsiasi server (a differenza di srand()/rand() che
//  cambia comportamento tra PHP 7 e PHP 8).
//
//  Il seed determina l'esito:
//  - Se h è valida: seed = K del giorno → stessi colori per
//    tutti gli scontrini del giorno (il direttore può confrontare)
//  - Se h è errata/mancante: seed avvelenato → colori casuali
//    diversi da quelli legittimi (trappola silenziosa per bot
//    e falsari che interrogano il server senza QR fisico)
// ============================================================

function generaMondrian(int $seed): array {
    $palette = [
        '#E63946', // rosso
        '#2A9D8F', // verde acqua
        '#264653', // blu scuro
        '#E9C46A', // giallo
        '#F4A261', // arancio
        '#A8DADC', // azzurro chiaro
        '#457B9D', // blu medio
        '#1D3557', // blu notte
        '#F1FAEE', // bianco panna
        '#E76F51', // corallo
    ];
    $colors = [];
    // Assicura che il seed sia positivo a 31 bit
    $s = $seed & 0x7FFFFFFF;
    for ($i = 0; $i < 4; $i++) {
        // LCG: parametri identici a glibc (gcc standard)
        $s        = ($s * 1664525 + 1013904223) & 0x7FFFFFFF;
        $colors[] = $palette[$s % count($palette)];
    }
    return $colors;
}

